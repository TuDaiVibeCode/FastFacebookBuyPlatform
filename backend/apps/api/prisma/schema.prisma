generator client {
  provider = "prisma-client-py"
  output   = "../.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  password_hash  String
  created_at    DateTime @default(now())

  @@map("users")
}
