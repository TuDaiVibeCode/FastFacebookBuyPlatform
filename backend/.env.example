# Copy this file to .env before deployment:
#   cp .env.example .env
#
# Docker Compose reads these values when you run it from the backend directory
# or pass --env-file .env explicitly.

COMPOSE_PROJECT_NAME=deal-radar

# API container
API_IMAGE=deal-radar-api:local
API_HTTP_PORT=18000
API_HOST=0.0.0.0
API_PORT=8000
API_NAME="Deal Radar API"
API_VERSION=0.1.0

# Application behavior
EXACT_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_THRESHOLD=0.90
USE_MOCK_LLM=true
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=20
STRICT_SOURCE_POLICY=false
SAMPLE_DATA_DIR=/workspace/backend/packages/sample-data

# Internal service URLs used by the API container.
REDIS_URL=redis://redis:6379/0
CHROMA_URL=http://chromadb:8000

# Host ports for direct access during deployment checks.
REDIS_HOST_PORT=16379
CHROMA_HOST_PORT=18001

# ChromaDB
CHROMA_IMAGE=chromadb/chroma:0.5.23
CHROMA_PERSIST_DIRECTORY=/chroma/chroma
CHROMA_ANONYMIZED_TELEMETRY=FALSE

